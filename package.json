{
  "name": "si-chen",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:relay": "tsx server/llm/anthropicRelay.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:relay\"",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck:client": "tsc --noEmit",
    "typecheck:server": "tsc -p server/tsconfig.json --noEmit",
    "typecheck": "npm run typecheck:client && npm run typecheck:server",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "validate-content": "tsx tools/validate-content.ts",
    "validate-manifest": "tsx tools/validate-manifest.ts",
    "gen-placeholders": "tsx tools/gen-placeholders.ts",
    "new:character": "tsx tools/new-content.ts character",
    "new:location": "tsx tools/new-content.ts location",
    "new:event": "tsx tools/new-content.ts event",
    "new:scene": "tsx tools/new-content.ts scene",
    "smoke:anthropic": "tsx tools/smoke-anthropic.ts",
    "eval:run": "tsx tools/eval-run.ts",
    "eval:score": "tsx tools/eval-score.ts",
    "eval:export": "tsx tools/eval-export.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@google/genai": "^2.9.0",
    "openai": "^6.44.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.1.2",
    "eslint": "^10.4.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
