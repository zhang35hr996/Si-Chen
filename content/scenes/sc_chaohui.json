      "id": "n_choice",
      "choices": [
        { "id": "c_army", "text": "军饷照准。北境将士，不可寒心。", "tone": "neutral", "next": "n_fx_army" },
        { "id": "c_clan", "text": "世家所请，朕准了。", "tone": "friendly", "next": "n_fx_clan" },
