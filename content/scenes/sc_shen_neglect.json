      "id": "n_choice",
      "choices": [
        { "id": "c_comfort", "text": "近来政务缠身，是朕疏忽了你。", "tone": "friendly", "next": "n_fx_comfort" },
        { "id": "c_brush", "text": "朕路过而已，你自便。", "tone": "neutral", "next": "n_fx_brush" },
        { "id": "c_cold", "text": "这话说的不老实，不可窥伺帝踪。", "tone": "hostile", "next": "n_fx_cold" }
