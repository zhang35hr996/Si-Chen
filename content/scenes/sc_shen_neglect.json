    {
      "type": "line",
      "id": "n_open",
      "speaker": "lu_huaijin",
      "text": "陛下万福金安。臣侍在御花园赏花，竟有幸见驾临，臣侍喜不自胜。",
      "expression": "frown",
      "next": "n_choice"
    },
    {
      "type": "choice",
      "id": "n_choice",
      "choices": [
        {
          "id": "c_comfort",
          "text": "近来政务缠身，是朕疏忽了你。",
          "tone": "friendly",
          "next": "n_fx_comfort"
        },
        {
          "id": "c_brush",
          "text": "朕路过而已，你自便。",
          "tone": "neutral",
          "next": "n_fx_brush"
        },
        {
          "id": "c_cold",
          "text": "这话说的不老实，不可窥伺帝踪。",
          "tone": "hostile",
          "next": "n_fx_cold"
        }
      ]
    },
    {
      "type": "effect",
      "id": "n_fx_comfort",
      "effects": [
        {
          "type": "memory",
          "char": "lu_huaijin",
          "entry": {
            "kind": "episodic",
            "summary": "陛下在御花园亲口说，是政务缠身疏忽了我。这句话，我等了三旬。",
            "strength": 70,
            "retention": "permanent",
            "subjectIds": [
