      ],
      "next": "n_end_comfort"
    },
    {
      "type": "line",
      "id": "n_end_comfort",
      "speaker": "lu_huaijin",
      "text": "……臣侍失仪了。陛下既肯来，这园子的花，便不算白开。",
      "expression": "smile"
    },
    {
      "type": "effect",
      "id": "n_fx_brush",
      "effects": [
        {
          "type": "memory",
          "char": "lu_huaijin",
          "entry": {
            "kind": "episodic",
            "summary": "陛下说只是路过。三旬不见，等来一句『你自便』。",
            "strength": 65,
            "retention": "slow",
            "subjectIds": [
              "player",
              "lu_huaijin"
            ],
            "perspective": "witness",
            "triggerTags": [
              "neglect",
              "yuhuayuan"
            ],
            "unresolved": true,
            "emotions": {
              "grief": 40
            }
          }
        }
      ],
      "next": "n_end_brush"
    },
    {
      "type": "line",
      "id": "n_end_brush",
      "speaker": "lu_huaijin",
      "text": "是，陛下慢走。臣侍恭送陛下。",
      "expression": "frown"
    },
    {
      "type": "effect",
      "id": "n_fx_cold",
      "effects": [
        {
          "type": "memory",
          "char": "lu_huaijin",
          "entry": {
            "kind": "episodic",
            "summary": "陛下说我话不老实，不可窥伺帝踪。希望陛下不会降罪。",
            "strength": 75,
            "retention": "permanent",
            "subjectIds": [
