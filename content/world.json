  "bedchamberScript": {
    "passion": {
      "lines": [
        "{name}闻召，颊上飞红，敛衽称是，缓步上前服侍帝王。",
        "帐暖香浓，{self}屏息承欢，曲意逢迎，不敢有半分懈怠。",
        "云收雨歇，陛下倦极而眠，只觉通体舒泰、神清气爽。"
      ]
    },
    "pleasure": {
      "lines": [
        "{name}奉召近前，执扇研墨、抚琴奉茶，柔声为帝王解乏。",
        "一夕清谈相伴，陛下心绪舒展，只觉神清气爽，并无他事。"
      ]
    },
    "companionship": {
      "lines": [
        "{name}近前相伴，理妆奉茶、轻声叙话，陪着陛下闲话家常。",
        "一夕静好相守，陛下心绪安宁，{self}亦觉受用圣眷。"
      ],
      "sovereignPregnant": [
        "{name}见陛下凤体有孕，愈发小心翼翼，扶坐奉茶，轻声宽慰，唯恐惊动龙胎。",
        "一夕静守相伴，{self}只盼陛下安心养胎，母子平安。"
      ],
      "consortPregnant": [
        "{name}腹中已怀皇嗣，行动渐缓。陛下亲来探视，命其安坐，不必多礼。",
        "{self}抚腹谢恩，言必尽心护持腹中骨血，不负圣望。"
      ],
      "bothPregnant": [
        "陛下与{name}皆怀身孕，相对而坐，竟生出几分惺惺相惜之意。",
        "一夕静好，彼此叮咛保重，宫人在侧伺候，唯恐有失。"
      ]
    }
  },
